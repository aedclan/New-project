# Server
HOST=0.0.0.0
PORT=5173

# Server sync and persistent data
PERSONAL_HUB_SYNC_TOKEN=
PERSONAL_HUB_DATA_FILE=.data/personal-hub-data.json

# Real login
PERSONAL_HUB_AUTH_DB_FILE=.data/personal-hub.sqlite
PERSONAL_HUB_ADMIN_USERNAME=admin
PERSONAL_HUB_ADMIN_PASSWORD=
PERSONAL_HUB_SESSION_MAX_AGE=604800
PERSONAL_HUB_REGISTRATION_ENABLED=false
PERSONAL_HUB_REGISTRATION_CODE=

# Backup
PERSONAL_HUB_BACKUP_DIR=.data/backups
PERSONAL_HUB_BACKUP_KEEP=14
PERSONAL_HUB_BACKUP_AUTO_ENABLED=true
PERSONAL_HUB_BACKUP_INTERVAL_HOURS=24
PERSONAL_HUB_BACKUP_ON_START=false

# Resend email notification service
# Get this from https://resend.com/api-keys
RESEND_API_KEY=
SUBSCRIPTION_EMAIL_FROM=
