# Server
HOST=0.0.0.0
PORT=5173

# Server sync and persistent data
PERSONAL_HUB_SYNC_TOKEN=
PERSONAL_HUB_DATA_FILE=.data/personal-hub-data.json

# Real login
PERSONAL_HUB_AUTH_DB_FILE=.data/personal-hub.sqlite
# New user registration requires email. The admin username may stay "admin" or be an email address.
PERSONAL_HUB_ADMIN_USERNAME=your-email@example.com
PERSONAL_HUB_ADMIN_PASSWORD=change-this-to-a-strong-password-2026!
PERSONAL_HUB_SESSION_MAX_AGE=604800
PERSONAL_HUB_SECURE_COOKIE=true
PERSONAL_HUB_REGISTRATION_ENABLED=false
PERSONAL_HUB_REGISTRATION_CODE=
AUTH_EMAIL_FROM=Personal Hub <notice@example.com>
AUTH_EMAIL_VERIFICATION_MAX_AGE=86400
AUTH_PASSWORD_RESET_MAX_AGE=3600
AUTH_REGISTER_CODE_MAX_AGE=600
AUTH_REGISTER_CODE_COOLDOWN=60
AUTH_REGISTER_CODE_MAX_ATTEMPTS=5
PUBLIC_SITE_URL=https://www.aedclan.com

# Backup
PERSONAL_HUB_BACKUP_DIR=.data/backups
PERSONAL_HUB_BACKUP_KEEP=14
PERSONAL_HUB_BACKUP_AUTO_ENABLED=true
PERSONAL_HUB_BACKUP_INTERVAL_HOURS=24
PERSONAL_HUB_BACKUP_ON_START=false

# VPS deploy helper
PERSONAL_HUB_APP_DIR=/opt/New-project
PERSONAL_HUB_DOMAIN=https://www.aedclan.com
PERSONAL_HUB_HEALTH_URL=http://127.0.0.1:5173/healthz

# Resend email notification service
# Get this from https://resend.com/api-keys
RESEND_API_KEY=
SUBSCRIPTION_EMAIL_FROM=

# Finance AI assistant / analysis
# Only aggregated finance summaries are sent by default.
FINANCE_AI_API_KEY=
FINANCE_AI_MODEL=
FINANCE_AI_API_URL=https://api.openai.com/v1/chat/completions
